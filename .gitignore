# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv
env/
venv/
ENV/

# =========================
# Jupyter Notebooks
# =========================
.ipynb_checkpoints/

# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# Claude Code
# =========================
.claude/
CLAUDE.md
memory/

# =========================
# Data (large, not redistributable)
# =========================
data/raw/
data/interim/
data/frames/
data/features/
data/labels/

!data/raw/.gitkeep
!data/interim/.gitkeep

# =========================
# Models — track trained classifiers, ignore the MediaPipe model file
# =========================
models/*.task
models/*.pkl
models/*.h5
models/*.pt

# =========================
# Logs / Temp
# =========================
*.log
tmp/
temp/

# =========================
# Media — ignore source videos / frames, but allow figures
# =========================
*.mp4
*.avi
*.mov
*.mkv

# =========================
# Presentation (slides not tracked)
# =========================
report/presentation.tex
report/presentation*.pdf
report/presentation.nav
report/presentation.snm
report/presentation.toc

# =========================
# LaTeX build artifacts
# =========================
*.aux
*.bbl
*.blg
*.out
*.fdb_latexmk
*.fls
*.synctex.gz

# =========================
# Mac / Misc
# =========================
*.swp
